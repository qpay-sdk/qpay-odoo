<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="payment_form_qpay" name="QPay Payment Form">
        <div id="qpay-payment-container" class="text-center">
            <div t-if="qpay_qr_image" class="mb-3">
                <h5>Scan QR code to pay</h5>
                <img t-att-src="'data:image/png;base64,' + qpay_qr_image"
                     alt="QPay QR Code"
                     style="max-width: 280px;"/>
            </div>

            <div t-if="qpay_qpay_short_url" class="mb-3">
                <a t-att-href="qpay_qpay_short_url"
                   class="btn btn-primary" target="_blank">
                    Pay with QPay
                </a>
            </div>

            <div t-if="qpay_urls" class="mb-3">
                <h6>Pay with bank app</h6>
                <div class="d-flex flex-wrap justify-content-center gap-2">
                    <t t-foreach="qpay_urls" t-as="bank">
                        <a t-att-href="bank.get('link', '')"
                           class="btn btn-outline-secondary btn-sm"
                           target="_blank">
                            <img t-if="bank.get('logo')"
                                 t-att-src="bank['logo']"
                                 style="height: 24px; width: 24px;"
                                 class="me-1"/>
                            <t t-esc="bank.get('name', '')"/>
                        </a>
                    </t>
                </div>
            </div>

            <div id="qpay-polling" class="mt-3">
                <div class="spinner-border spinner-border-sm text-primary" role="status"/>
                <span class="ms-2 text-muted">Waiting for payment...</span>
            </div>

            <input type="hidden" id="qpay-invoice-id"
                   t-att-value="qpay_invoice_id"/>
            <input type="hidden" id="qpay-check-url"
                   t-att-value="api_url"/>

            <script type="text/javascript">
                (function() {
                    var invoiceId = document.getElementById('qpay-invoice-id').value;
                    var checkUrl = document.getElementById('qpay-check-url').value;
                    var interval = setInterval(function() {
                        fetch(checkUrl, {
                            method: 'POST',
                            headers: {'Content-Type': 'application/json'},
                            body: JSON.stringify({jsonrpc: '2.0', params: {invoice_id: invoiceId}})
                        })
                        .then(function(r) { return r.json(); })
                        .then(function(data) {
                            if (data.result &amp;&amp; data.result.paid) {
                                clearInterval(interval);
                                document.getElementById('qpay-polling').innerHTML =
                                    '<span class="text-success fw-bold">Payment received!</span>';
                                setTimeout(function() { window.location.reload(); }, 1500);
                            }
                        })
                        .catch(function() {});
                    }, 3000);
                    setTimeout(function() { clearInterval(interval); }, 300000);
                })();
            </script>
        </div>
    </template>
</odoo>
