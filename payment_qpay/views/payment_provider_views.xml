<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payment_provider_form_qpay" model="ir.ui.view">
        <field name="name">payment.provider.form.qpay</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <group invisible="code != 'qpay'">
                    <field name="qpay_base_url"/>
                    <field name="qpay_username"/>
                    <field name="qpay_password" password="True"/>
                    <field name="qpay_invoice_code"/>
                </group>
            </group>
        </field>
    </record>
</odoo>
